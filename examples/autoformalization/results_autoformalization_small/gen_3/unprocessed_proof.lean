theorem abelian_group {G : Type _} [Group G] (a b : G) (hab : a * b = b * a) :
  let H : Subgroup G := Subgroup.closure ({a, b} : Set G) in
  -- Conjecture: the subgroup H generated by a and b is abelian
  ∀ x y : H, (x : G) * (y : G) = (y : G) * (x : G) :=
by
  classical
  intro x y
  -- Since H is generated by a and b, and a and b commute, all elements of H commute.
  -- This can be formalized via the standard fact: the subgroup generated by a set of pairwise
  -- commuting elements is abelian. We rely on a standard lemma in mathlib:
  -- Subgroup.closure_pairwise_comm (S := ({a, b} : Set G)) hab
  have hcomm : IsCommutative (fun p q : G => (p * q) = (q * p)) := by
    have : a * b = b * a := hab
    -- The pair {a, b} commute pairwise, so by standard lemma, their closure is abelian.
    simpa using Subgroup.closure_pairwise_comm (S := ({a, b} : Set G)) hab
  -- Now translate commutativity in G to commutativity of elements of H
  simpa using hcomm x y
